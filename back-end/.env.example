DATABASE_URL=postgresql://user:password@localhost:5432/talentmatch
PORT=3000

# Secret used to sign and verify access tokens.
AUTH_ACCESS_TOKEN_SECRET=change-me

# Access token lifetime in seconds.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token lifetime in seconds.
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# Maximum number of requests allowed within the auth rate-limit window.
AUTH_RATE_LIMIT_MAX=5

# Time window applied to login and refresh rate limiting.
AUTH_RATE_LIMIT_WINDOW=1 minute
